# Project: Password Strength Tester
# Purpose: Check whether a password contains at least one uppercase letter,
# one lowercase letter, and one number. The script assigns a strength label
# and keeps asking for a new password until all requirements are met.

import re


def check_password_strength(password: str) -> tuple[str, list[str], int]:
    """
    Check whether the password contains:
    - at least one uppercase letter
    - at least one lowercase letter
    - at least one number

    Returns:
        strength_label (str): Weak, Medium, or Strong
        missing_requirements (list[str]): Requirements the password does not meet
        requirements_met (int): Total number of requirements met
    """

    # Search the password for required character types
    has_uppercase = bool(re.search(r"[A-Z]", password))
    has_lowercase = bool(re.search(r"[a-z]", password))
    has_number = bool(re.search(r"[0-9]", password))

    # Count how many requirements were met
    requirements_met = sum([has_uppercase, has_lowercase, has_number])

    # Store any missing requirements in a list
    missing_requirements = []

    if not has_uppercase:
        missing_requirements.append("an uppercase letter")
    if not has_lowercase:
        missing_requirements.append("a lowercase letter")
    if not has_number:
        missing_requirements.append("a number")

    # Assign a strength label based on how many requirements were met
    if requirements_met == 3:
        strength_label = "Strong"
    elif requirements_met == 2:
        strength_label = "Medium"
    else:
        strength_label = "Weak"

    return strength_label, missing_requirements, requirements_met


def main() -> None:
    """Run the password tester until the user enters a strong password."""

    print("Password Strength Tester")
    print("-" * 25)

    # Keep asking the user for a password until all requirements are met
    while True:
        password = input("Enter a password to test: ").strip()

        # Handle empty input
        if not password:
            print("\nError: No password entered. Please try again.\n")
            continue

        # Check the password strength and display results
        strength_label, missing_requirements, requirements_met = check_password_strength(password)

        print("\nResults")
        print("-" * 25)
        print(f"Requirements met: {requirements_met}/3")
        print(f"Strength: {strength_label}")

        if missing_requirements:
            print("Missing:")
            for requirement in missing_requirements:
                print(f"- {requirement}")
            print("\nPlease try again.\n")
        else:
            print("Your password meets all requirements.")
            break


if __name__ == "__main__":
    main()
